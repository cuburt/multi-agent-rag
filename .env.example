# Database Configuration
DATABASE_URL=postgresql://dental_admin:dental_pass@localhost:5432/dental_rag

# LLM Configuration — Tiered Model Routing
# Three tiers map to agent nodes; each has a fallback chain in graph.py.
# Override only the primary model per tier here; fallbacks are hardcoded.
#
# ROUTER   → planner_node   (lightweight classification)
# AGENTIC  → scheduler_node (reasoning + structured output)
# SYNTHESIS→ summarizer_node(final response quality)
#
# All defaults are free OpenRouter models verified 2026-04-29.
ROUTER_MODEL=openrouter/meta-llama/llama-3.2-3b-instruct:free
AGENTIC_MODEL=openrouter/openai/gpt-oss-120b:free
SYNTHESIS_MODEL=openrouter/nousresearch/hermes-3-llama-3.1-405b:free

# Set the corresponding API key for the chosen model
GEMINI_API_KEY=your_gemini_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
# Vercel AI Gateway — final paid fallback when OpenRouter's free-tier 20 RPM cap trips.
VERCEL_API_KEY=your_vercel_ai_gateway_api_key_here

# Observability (Langfuse) - Optional for tracing
# Get keys from https://cloud.langfuse.com (free tier available)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
